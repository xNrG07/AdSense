---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOOLS } from '../../data/tools';
const other=TOOLS.filter(t=>t.slug!=='netto-brutto-schaetzer');
const jsonLd={'@context':'https://schema.org','@graph':[
  {'@type':'WebApplication',name:'Netto-Brutto-Schätzer Österreich 2026',url:'https://austrian-tools.at/tools/netto-brutto-schaetzer',applicationCategory:'FinanceApplication',operatingSystem:'All',offers:{'@type':'Offer',price:'0',priceCurrency:'EUR'}},
  {'@type':'FAQPage',mainEntity:[
    {'@type':'Question',name:'Wie berechnet sich das Netto vom Brutto in Österreich 2026?',acceptedAnswer:{'@type':'Answer',text:'Vom Brutto werden SV-Beiträge (DN-Anteil) und progressive Lohnsteuer (0–55%) abgezogen. Österreich hat 14 Gehälter/Jahr. Sonderzahlungen werden begünstigt besteuert (0% / 6% / 27% / 35,75%). Ab 2026 ist Einkommen bis € 13.539/Jahr steuerfrei.'}},
    {'@type':'Question',name:'Ist dieser Rechner offiziell?',acceptedAnswer:{'@type':'Answer',text:'Nein, dies ist ein Schätz-Tool. Für offizielle Berechnungen nutze den BMF-Rechner.'}},
    {'@type':'Question',name:'Warum 14 Gehälter?',acceptedAnswer:{'@type':'Answer',text:'Neben 12 Monatsgehältern gibt es Urlaubsgeld und Weihnachtsgeld. Diese Sonderzahlungen werden innerhalb des Jahressechstels begünstigt besteuert.'}}
  ]}
]};
---
<BaseLayout title="Netto-Brutto-Schätzer Österreich 2026 — Gehalt berechnen" description="Berechne kostenlos dein geschätztes Netto-Gehalt 2026 mit aktuellen österreichischen Steuersätzen und Sozialabgaben." jsonLd={jsonLd}>
<section class="section"><div class="container narrow">
  <nav class="bc"><a href="/">Start</a> / <a href="/tools">Tools</a> / Netto-Brutto-Schätzer</nav>
  <h1 class="mt-m">💰 Netto-Brutto-Schätzer 2026</h1>
  <p class="mt-s">Finde heraus, wie viel von deinem Brutto nach Steuern und Sozialabgaben übrig bleibt. Aktualisiert mit den Werten für 2026.</p>
  <div class="disc">⚠️ Schätz-Tool mit Richtwerten für 2026 (Quelle: BMF, WKO, ÖGK). Für verbindliche Berechnungen nutze den <a href="https://www.bmf.gv.at/services/berechnungsprogramme.html" target="_blank" rel="noopener">BMF-Rechner</a>. Keine Steuerberatung.</div>

  <div class="card mt-l" id="tool">
    <div class="presets"><span class="presets-l">Beispiele:</span>
      <button class="btn btn-s btn-sm" data-p="2000">€ 2.000</button>
      <button class="btn btn-s btn-sm" data-p="2500">€ 2.500</button>
      <button class="btn btn-s btn-sm" data-p="3500">€ 3.500</button>
      <button class="btn btn-s btn-sm" data-p="5000">€ 5.000</button>
    </div>
    <div class="fg"><label for="brutto">Monatliches Brutto-Gehalt (€)</label>
      <input type="number" id="brutto" min="0" max="100000" step="50" placeholder="z.B. 3000"/>
      <div class="hint">14× jährlich (inkl. Urlaubs- & Weihnachtsgeld)</div>
      <div class="err" id="bErr" style="display:none"></div>
    </div>
    <button class="btn btn-p" id="calc">Netto schätzen</button>
    <div id="res" style="display:none">
      <div class="rc">
        <div class="rc-t">Geschätztes Netto-Gehalt</div>
        <div class="rc-v" id="rNet">-</div>
        <div class="hint">pro Monat (14× jährlich) — Werte 2026</div>
        <div style="margin-top:1rem">
          <div class="rr"><span class="rr-l">Brutto monatlich</span><span class="rr-v" id="rB">-</span></div>
          <div class="rr"><span class="rr-l">Sozialversicherung (DN-Anteil)</span><span class="rr-v" id="rSV">-</span></div>
          <div class="rr"><span class="rr-l">Lohnsteuer (geschätzt)</span><span class="rr-v" id="rTx">-</span></div>
          <div class="rr"><span class="rr-l">Brutto jährlich (14×)</span><span class="rr-v" id="rYB">-</span></div>
          <div class="rr"><span class="rr-l">Netto jährlich (geschätzt)</span><span class="rr-v" id="rYN">-</span></div>
          <div class="rr"><span class="rr-l">SV-Satz (DN)</span><span class="rr-v" id="rSVR">-</span></div>
        </div>
      </div>
      <div class="ra">
        <button class="btn btn-s btn-sm" id="copy">📋 Kopieren</button>
        <button class="btn btn-s btn-sm" id="share">🔗 Teilen</button>
        <button class="btn btn-s btn-sm" id="save">💾 Speichern</button>
      </div>
      <div id="msg" class="hint mt-s" style="display:none;color:var(--ok)"></div>
    </div>
  </div>

  <div class="ad" data-ad-slot="incontent_2" style="margin-top:2rem">Anzeige Placeholder</div>

  <section class="mt-2xl"><h2>Häufige Fragen</h2><div class="faq">
    <details><summary>Wie berechnet sich das Netto vom Brutto 2026?</summary><p>Vom Brutto werden zunächst SV-Beiträge abgezogen (Dienstnehmer-Anteil: KV 3,87% + PV 10,25% + ALV bis 2,95% + WBF 0,5% + AK 0,5%). Vom Rest wird progressive Lohnsteuer berechnet. Ab 2026 ist Einkommen bis € 13.539/Jahr steuerfrei. Der Verkehrsabsetzbetrag (€ 496/Jahr) wird berücksichtigt. Sonderzahlungen (13./14.) werden innerhalb des Jahressechstels begünstigt besteuert.</p></details>
    <details><summary>Was ändert sich 2026?</summary><p>Die Steuerstufen wurden um 1,733% angehoben (Abschaffung kalte Progression). Die Höchstbeitragsgrundlage steigt auf € 6.930/Monat. Die Geringfügigkeitsgrenze bleibt bei € 551,10.</p></details>
    <details><summary>Was ist die Höchstbeitragsgrundlage?</summary><p>Ab 2026: € 6.930/Monat. Darüber fällt keine SV an, aber weiterhin Lohnsteuer.</p></details>
    <details><summary>Warum 14 Gehälter in Österreich?</summary><p>Neben 12 regulären Gehältern gibt es Urlaubsgeld und Weihnachtsgeld. Diese Sonderzahlungen werden – innerhalb des Jahressechstels – begünstigt besteuert (0% / 6% / 27% / 35,75%).</p></details>
    <details><summary>Ist dieser Rechner offiziell?</summary><p>Nein – es ist ein Schätz-Tool. Für verbindliche Zahlen: <a href="https://www.bmf.gv.at/services/berechnungsprogramme.html" target="_blank" rel="noopener">BMF-Brutto-Netto-Rechner</a>.</p></details>
  </div></section>

  <section class="mt-2xl"><h2>Weitere Tools</h2><div class="rg">{other.map(t=><a href={t.href} class="rl"><div class="rl-e">{t.emoji}</div><div class="rl-t">{t.title}</div><div class="rl-d">{t.desc}</div></a>)}</div></section>
  <section class="mt-2xl"><h2>Passende Artikel</h2><div class="rg">
    <a href="/blog/netto-vs-brutto" class="rl"><div class="rl-e">📝</div><div class="rl-t">Netto vs. Brutto in Österreich</div></a>
    <a href="/blog/steuererklarung-basics" class="rl"><div class="rl-e">📝</div><div class="rl-t">Steuererklärung: die Basics</div></a>
  </div></section>
</div></section>
</BaseLayout>
<script is:inline>
/**
 * Netto-Brutto Calculator — 2026 values
 * Sources: BMF Steuertarif 2026, WKO Beitragswesen DN 2026, ÖGK
 */
const fmt = v => new Intl.NumberFormat('de-AT',{style:'currency',currency:'EUR'}).format(v);

// 2026 tax brackets (annual)
const BRACKETS = [
  {f:0,     t:13539,   r:0},
  {f:13539, t:21992,   r:0.20},
  {f:21992, t:36458,   r:0.30},
  {f:36458, t:70365,   r:0.40},
  {f:70365, t:104859,  r:0.48},
  {f:104859,t:1000000, r:0.50},
  {f:1000000,t:Infinity,r:0.55},
];

// SV rates 2026 — DN share (WKO)
// Regular months: KV 3.87% + PV 10.25% + WBF 0.50% + AK 0.50% = 15.12% (without ALV)
// Sonderzahlungen: no WBF + AK (WKO) → KV 3.87% + PV 10.25% = 14.12% (without ALV)
// DN-ALV depends on income: <=2225: 0%, 2225-2427: 1%, 2427-2630: 2%, >2630: 2.95%
const SV_BASE_REGULAR = 0.1512; // KV+PV+WBF+AK
const SV_BASE_SPECIAL = 0.1412; // KV+PV (no WBF+AK)
const MAX_SV_BASIS = 6930;
const MAX_SV_SONDER = 13860;
const VERKEHRS_AB = 496; // annual
const SZ_FREIBETRAG = 620;
const SZ_FREIGRENZE = 2615;

function getALVRate(monthlyBrutto) {
  if (monthlyBrutto <= 2225) return 0;
  if (monthlyBrutto <= 2427) return 0.01;
  if (monthlyBrutto <= 2630) return 0.02;
  return 0.0295;
}

function calcTax(annualIncome) {
  let tax = 0;
  for (const b of BRACKETS) {
    if (annualIncome <= b.f) break;
    tax += (Math.min(annualIncome, b.t) - b.f) * b.r;
  }
  return tax;
}

function calculate(brutto) {
  const alvRate = getALVRate(brutto);

  // SV split: 12 regular months + 2 Sonderzahlungen (with special caps and rates)
  const regularBasis = Math.min(brutto, MAX_SV_BASIS);
  const svRateRegular = SV_BASE_REGULAR + alvRate;
  const regularSV = regularBasis * svRateRegular * 12;

  const specialGross = brutto * 2;
  const specialBasisTotal = Math.min(specialGross, MAX_SV_SONDER);
  const svRateSpecial = SV_BASE_SPECIAL + alvRate;
  const specialSV = specialBasisTotal * svRateSpecial;

  const annualBrutto = brutto * 14;
  const annualSV = regularSV + specialSV;

  // Tax base split
  const regularTaxable = (brutto * 12) - regularSV;
  const specialTaxable = specialGross - specialSV;

  // Regular tax (tariff)
  const regularTax = calcTax(regularTaxable);
  const regularTaxAfterVAB = Math.max(0, regularTax - VERKEHRS_AB);

  // Sonderzahlungen tax (within Jahressechstel) — simplified but aligned with the fixed-rate table
  // If Jahressechstel is under the Freigrenze, no tax is withheld on SZ with the fixed rate.
  const jahressechstel = brutto * 2;
  let szTax = 0;
  if (jahressechstel > SZ_FREIGRENZE) {
    let base = Math.max(0, specialTaxable - SZ_FREIBETRAG);
    const steps = [
      { cap: 24380, rate: 0.06 },
      { cap: 25000, rate: 0.27 },
      { cap: 33333, rate: 0.3575 },
    ];
    for (const s of steps) {
      if (base <= 0) break;
      const part = Math.min(base, s.cap);
      szTax += part * s.rate;
      base -= part;
    }
    // Overhang (rare for standard 13./14.): taxed like regular income
    if (base > 0) {
      szTax += (calcTax(regularTaxable + base) - calcTax(regularTaxable));
    }
  }

  const totalTax = regularTaxAfterVAB + szTax;
  const annualNetto = annualBrutto - annualSV - totalTax;
  const monthlyNetto = annualNetto / 14;

  const svMonthlyAvg = annualSV / 14;
  const svRateMax = svRateRegular;
  return { brutto, svMonthly: svMonthlyAvg, svRate: svRateMax, taxMonthly: totalTax/14, nettoMonthly: monthlyNetto, annualBrutto, annualNetto };
}

function run() {
  const v = parseFloat(document.getElementById('brutto').value);
  const e = document.getElementById('bErr');
  if (isNaN(v) || v < 0 || v > 100000) {
    e.textContent = 'Gültiges Gehalt eingeben (0–100.000).';
    e.style.display = 'block';
    document.getElementById('res').style.display = 'none';
    return;
  }
  e.style.display = 'none';
  const r = calculate(v);
  document.getElementById('rNet').textContent = fmt(r.nettoMonthly);
  document.getElementById('rB').textContent = fmt(r.brutto);
  document.getElementById('rSV').textContent = '− ' + fmt(r.svMonthly);
  document.getElementById('rTx').textContent = '− ' + fmt(r.taxMonthly);
  document.getElementById('rYB').textContent = fmt(r.annualBrutto);
  document.getElementById('rYN').textContent = fmt(r.annualNetto);
  document.getElementById('rSVR').textContent = (r.svRate * 100).toFixed(2) + '%';
  document.getElementById('res').style.display = 'block';
}

document.getElementById('calc').addEventListener('click', run);
document.getElementById('brutto').addEventListener('keydown', e => { if (e.key === 'Enter') run(); });
document.querySelectorAll('[data-p]').forEach(b => b.addEventListener('click', () => {
  document.getElementById('brutto').value = b.dataset.p; run();
}));

function flash(t) {
  const m = document.getElementById('msg');
  m.textContent = t; m.style.display = 'block';
  setTimeout(() => m.style.display = 'none', 2000);
}
document.getElementById('copy')?.addEventListener('click', async () => {
  const t = 'Netto-Brutto 2026 (AT): Brutto € ' + document.getElementById('brutto').value + ' → Netto ' + document.getElementById('rNet').textContent + '\naustrian-tools.at';
  await navigator.clipboard.writeText(t); flash('✓ Kopiert!');
});
document.getElementById('share')?.addEventListener('click', () => {
  const u = new URL(location.href); u.search = '';
  u.searchParams.set('brutto', document.getElementById('brutto').value);
  navigator.clipboard.writeText(u.toString()); flash('✓ Link kopiert!');
});
document.getElementById('save')?.addEventListener('click', () => {
  try {
    const k = 'at_nb', x = JSON.parse(localStorage.getItem(k) || '[]');
    x.unshift({b: document.getElementById('brutto').value, n: document.getElementById('rNet').textContent, t: new Date().toISOString()});
    localStorage.setItem(k, JSON.stringify(x.slice(0, 10))); flash('✓ Gespeichert!');
  } catch {}
});

// URL params
const ps = new URLSearchParams(location.search);
if (ps.get('brutto')) { document.getElementById('brutto').value = ps.get('brutto'); run(); }
</script>
